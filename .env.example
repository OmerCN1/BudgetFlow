VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Supabase Edge Function secret olarak tanımlayın; frontend .env içine gerçek API key koymayın.
# SUPABASE_URL ve SUPABASE_SERVICE_ROLE_KEY Supabase Edge Functions ortamında bulunmalıdır.
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_RECEIPT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# E-posta bildirimleri (Resend) — https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=BudgetAssist <noreply@yourdomain.com>

# SMS bildirimleri (Twilio) — https://twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx
